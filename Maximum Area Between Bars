/////           Maximum Area Between Bars          //////




class Solution {
    public int maxArea(List<Integer> height) {
        int n = height.size();
        if (n < 2) return 0;

        int left = 0, right = n - 1;
        int maxArea = 0;

        while (left < right) {
            int widthBetween = right - left - 1; 
            int area = Math.min(height.get(left), height.get(right)) * widthBetween;
            maxArea = Math.max(maxArea, area);

            if (height.get(left) < height.get(right)) {
                left++;
            } else {
                right--;
            }
        }

        return maxArea;
    }
}
